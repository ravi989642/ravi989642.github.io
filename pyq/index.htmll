];

/* VARIABLES */

let currentQuestion = 0;
let score = 0;
let attempted = 0;
let wrong = 0;
let answeredCurrent = false;

/* LOAD QUESTION */

function loadQuestion(){

    const q = quizData[currentQuestion];

    document.getElementById("question").innerText = q.question;
    document.getElementById("subject").innerText = "📍 " + q.subject;
    document.getElementById("exam").innerText = "📝 " + q.exam;
    document.getElementById("extra").innerText = q.extra;

    document.getElementById("qno").innerText =
    `${currentQuestion+1}/25`;

    const progress =
    ((currentQuestion+1)/quizData.length)*100;

    document.getElementById("progressFill").style.width =
    progress + "%";

    document.getElementById("progressText").innerText =
    Math.floor(progress) + "%";

    const optionsDiv =
    document.getElementById("options");

    optionsDiv.innerHTML = "";

    q.options.forEach((option,index)=>{

        const letters = ["A","B","C","D"];

        const div = document.createElement("div");

        div.classList.add("option");

        div.innerHTML = `

            <div class="option-letter">
                ${letters[index]}
            </div>

            <div class="option-text">
                ${option}
            </div>

        `;

        div.onclick = ()=>checkAnswer(div,option);

        optionsDiv.appendChild(div);

    });

    // HIDE EXTRA BOX ON NEW QUESTION
    document.getElementById("extraBox").style.display = "none";
    answeredCurrent = false;

    // UPDATE SIDE IMAGE
    document.getElementById("questionImage").src = q.image;
    document.getElementById("imageCaption").innerText = q.imageCaption || "";

    updateNavigator();

}

/* CHECK ANSWER */

function checkAnswer(element,selected){

    if(answeredCurrent) return;
    answeredCurrent = true;

    const correctAnswer =
    quizData[currentQuestion].answer;

    const allOptions =
    document.querySelectorAll(".option");

    attempted++;

    allOptions.forEach(opt=>{

        opt.style.pointerEvents = "none";

        if(opt.innerText.includes(correctAnswer)){
            opt.classList.add("correct");
        }

    });

    if(selected===correctAnswer){

        score++;

    }else{

        wrong++;
        element.classList.add("wrong");

    }

    // SHOW EXTRA KNOWLEDGE
    document.getElementById("extraBox").style.display = "block";

    updatePerformance();

}

/* SHOW ANSWER BUTTON */

function showAnswer(){
    if(answeredCurrent) return;
    answeredCurrent = true;

    const correctAnswer = quizData[currentQuestion].answer;
    const allOptions = document.querySelectorAll(".option");

    allOptions.forEach(opt => {
        opt.style.pointerEvents = "none";
        if(opt.innerText.includes(correctAnswer)){
            opt.classList.add("correct");
        }
    });

    // SHOW EXTRA KNOWLEDGE WITHOUT SCORING
    document.getElementById("extraBox").style.display = "block";
}

/* PERFORMANCE */

function updatePerformance(){

    document.getElementById("score").innerText = score;
    document.getElementById("attempted").innerText = attempted;
    document.getElementById("correct").innerText = score;
    document.getElementById("wrong").innerText = wrong;

    let accuracy = attempted===0 ? 0 :
    Math.floor((score/attempted)*100);

    document.getElementById("accuracy").innerText =
    accuracy + "%";

}

/* NEXT */

function nextQuestion(){

    currentQuestion++;

    if(currentQuestion >= quizData.length){

        alert("🎉 Quiz Completed!");
        currentQuestion = 0;

    }

    loadQuestion();

}

/* PREVIOUS */

function prevQuestion(){

    if(currentQuestion > 0){

        currentQuestion--;
        loadQuestion();

    }

}

/* NAVIGATION */

function updateNavigator(){

    const grid =
    document.getElementById("questionGrid");

    grid.innerHTML = "";

    for(let i=0;i<<quizData.length;i++){

        const div =
        document.createElement("div");

        div.classList.add("q-number");

        if(i===currentQuestion){

            div.classList.add("active-q");

        }

        div.innerText = i+1;

        div.onclick = ()=>{

            currentQuestion = i;
            loadQuestion();

        };

        grid.appendChild(div);

    }

}

/* FULLSCREEN */

function toggleFullscreen(){

    if(!document.fullscreenElement){

        document.documentElement.requestFullscreen();

    }else{

        document.exitFullscreen();

    }

}

/* TIMER */

let totalTime = 1800;

setInterval(()=>{

    let minutes =
    Math.floor(totalTime/60);

    let seconds =
    totalTime%60;

    seconds =
    seconds < 10 ? "0"+seconds : seconds;

    document.getElementById("timer").innerText =
    `${minutes}:${seconds}`;

    if(totalTime>0){

        totalTime--;

    }

},1000);

/* START */

loadQuestion();

</script>

</body>
</html>
